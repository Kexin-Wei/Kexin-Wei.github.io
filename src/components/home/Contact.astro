---
import { profile } from '~/data/profile'
---

<section id="contact" class="rule-t mt-16 lg:mt-24 pt-6 pb-16 grid gap-6 lg:grid-cols-2">
  <div flex="~ col gap-4">
    <h2 class="m-0 font-ui font-normal c-primary" style="font-size: clamp(1.75rem, 4vw, 3rem); line-height: 1.1;">
      Let's Collaborate
    </h2>
    <p class="m-0 max-w-md text-4 c-secondary">
      I am always open to new ideas, interesting problems and collaborative projects — in robotics, AI or anything in
      between.
    </p>
  </div>
  <div flex="~ col gap-3" class="lg:items-end lg:justify-end">
    <a href={`mailto:${profile.email}`} class="mono-link not-underline-hover">Get in Touch &gt;</a>
    <a href={profile.resume} class="mono-link not-underline-hover">Download Resume &gt;</a>
  </div>
</section>
