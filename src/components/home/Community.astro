---
import { profile } from '~/data/profile'
import PixelGrid from '~/components/home/PixelGrid.astro'

const groups = [
  { label: 'Open Source', accent: 'c-accent-blue', items: profile.openSource },
  { label: 'Community', accent: 'c-accent', items: profile.community },
]
---

<section class="rule-t mt-16 lg:mt-24 pt-6">
  <h2 class="m-0 mb-10 font-ui font-normal c-primary" style="font-size: clamp(1.75rem, 4vw, 3rem); line-height: 1.1;">
    Community & Open Source
  </h2>
  <div class="grid gap-10 lg:grid-cols-2 lg:gap-6">
    {
      groups.map(group => (
        <div class="rule-t pt-4" flex="~ col gap-6">
          <h3 class="m-0 font-ui font-normal text-6 c-primary">{group.label}</h3>
          <ul class="m-0 p-0" style="list-style: none;" flex="~ col gap-6">
            {
              group.items.map((item, idx) => (
                <li class="grid gap-4" style="grid-template-columns: 2.5rem 1fr; align-items: start;">
                  {item.logo ? (
                    <img
                      src={item.logo}
                      alt=""
                      loading="lazy"
                      style={`width: 2.5rem; height: 2.5rem; object-fit: contain; border-radius: 4px; padding: 3px;${item.logoBg === 'dark' ? ' background: #0f172a;' : ''}`}
                    />
                  ) : (
                    <PixelGrid
                      cols={8}
                      rows={8}
                      seed={idx * 17 + 2}
                      icons={item.icons ?? ['code', 'node']}
                      class={`w-full h-auto ${group.accent}`}
                    />
                  )}
                  <span flex="~ col gap-1">
                    {item.href ? (
                      <a href={item.href} target="_blank" rel="noopener noreferrer" class="community-link m-0 text-4 c-primary">
                        {item.title} <span class="text-3 c-secondary">↗</span>
                      </a>
                    ) : (
                      <span class="m-0 text-4 c-primary">{item.title}</span>
                    )}
                    <span class="text-3.5 c-secondary">{item.description}</span>
                  </span>
                </li>
              ))
            }
          </ul>
        </div>
      ))
    }
  </div>
</section>

<style>
  .community-link {
    text-decoration: none;
  }
  .community-link:hover {
    text-decoration: underline;
    text-underline-offset: 3px;
  }
</style>
