---
import { profile } from '~/data/profile'
import PixelGrid from '~/components/home/PixelGrid.astro'
---

<section>
  <div class="rule-t pt-4 pb-10 lg:pb-16">
    <h1
      class="m-0 font-header font-bold uppercase c-primary"
      style="font-size: clamp(2.5rem, 8.5vw, 6rem); line-height: 0.9; letter-spacing: -0.04em;"
    >
      {profile.name}
    </h1>
    <p class="mt-5 mono-label c-muted uppercase">{profile.role} · {profile.location}</p>
    <p class="mt-2 max-w-2xl text-4 lg:text-4.5 c-secondary font-medium">{profile.tagline}</p>
  </div>

  <div class="rule-t pt-6 grid gap-6 lg:grid-cols-[2fr_1fr] items-start">
    <PixelGrid cols={38} rows={16} seed={11} class="w-full h-auto c-accent-alt" />
    <div flex="~ col gap-4">
      <img src={profile.avatar} alt={profile.name} class="w-full max-w-70 h-auto" loading="eager" />
      <a href="/posts/" class="mono-link not-underline-hover">Read My Posts &gt;</a>
    </div>
  </div>
</section>
