---
import { themeConfig } from '~/.config'
import { profile } from '~/data/profile'

const year = new Date().getFullYear()
const { navLinks } = themeConfig.site
---

<footer class="rule-t mt-8 pt-6 pb-10 grid gap-8 lg:grid-cols-4 lg:gap-6 text-3.5">
  <span class="mono-label c-muted">Connect</span>

  <div flex="~ col gap-1" class="c-secondary">
    <span>{profile.location}</span>
    <a href={`mailto:${profile.email}`} class="not-underline-hover hover:op-60">{profile.email}</a>
  </div>

  <div flex="~ col gap-1">
    {
      profile.socials.map((social) => (
        <a href={social.href} target="_blank" class="not-underline-hover c-secondary hover:op-60">
          {social.label}
        </a>
      ))
    }
    <a href="/atom.xml" class="not-underline-hover c-secondary hover:op-60">RSS</a>
  </div>

  <div flex="~ col gap-1">
    <nav flex="~ col gap-1">
      {
        navLinks.map((nav) => (
          <a href={nav.href} class="not-underline-hover c-secondary hover:op-60">
            {nav.name}
          </a>
        ))
      }
    </nav>
    <a href="/logseq_notes/" class="not-underline-hover c-muted text-3 op-70 hover:op-100">Logseq Notes</a>
    <span class="mt-3 c-muted">© {year} {profile.name}</span>
  </div>
</footer>
