---
/**
 * Animated halftone field replicating the Wix template's looping videos.
 * Rendering and animation live in ~/scripts/pixel-grid.ts; this component
 * just emits the canvas with its parameters.
 */
import type { PixelIcon } from '~/data/profile'

interface Props {
  cols?: number
  rows?: number
  seed?: number
  icons?: PixelIcon[]
  class?: string
}

const {
  cols = 48,
  rows = 22,
  seed = 7,
  icons = ['robot', 'gear', 'chip', 'wave', 'node', 'code'],
  class: className,
} = Astro.props

const size = 12
const step = size + 4
---

<canvas
  data-pixel-grid
  data-cols={cols}
  data-rows={rows}
  data-seed={seed}
  data-icons={icons.join(',')}
  width={cols * step}
  height={rows * step}
  class={className}
  aria-hidden="true"></canvas>

<script>
  import '~/scripts/pixel-grid'
</script>
