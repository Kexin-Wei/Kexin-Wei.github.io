---
/**
 * Decorative glyph field inspired by the Researcher CV template, themed to
 * the site's content: a cluster of solid squares dissolves into tiny
 * hand-drawn icons (robot, gear, chip, sine wave, neural node, code)
 * with a subtle twinkle. Pure inline SVG — deterministic per seed.
 */
import type { PixelIcon } from '~/data/profile'

interface Props {
  cols?: number
  rows?: number
  seed?: number
  icons?: PixelIcon[]
  class?: string
}

const {
  cols = 48,
  rows = 22,
  seed = 7,
  icons = ['robot', 'gear', 'chip', 'wave', 'node', 'code'],
  class: className,
} = Astro.props

// Deterministic pseudo-random (mulberry32) so the pattern is stable per build
function mulberry32(a: number) {
  return () => {
    a |= 0
    a = (a + 0x6d2b79f5) | 0
    let t = Math.imul(a ^ (a >>> 15), 1 | a)
    t = (t + Math.imul(t ^ (t >>> 7), 61 | t)) ^ t
    return ((t ^ (t >>> 14)) >>> 0) / 4294967296
  }
}

const rand = mulberry32(seed)

// Two soft cluster centers give the field an organic, asymmetric weight
const centers = [
  { cx: 0.38 + rand() * 0.1, cy: 0.45 + rand() * 0.2, spread: 2.1 },
  { cx: 0.68 + rand() * 0.1, cy: 0.35 + rand() * 0.3, spread: 3.2 },
]

function density(x: number, y: number): number {
  let d = 0
  for (const { cx, cy, spread } of centers) {
    const dx = x / cols - cx
    const dy = y / rows - cy
    d = Math.max(d, 1 - Math.sqrt(dx * dx + dy * dy) * spread)
  }
  return Math.max(0, d)
}

const size = 12
const step = size + 4
const width = cols * step
const height = rows * step

// One shared cycle; each cell's delay follows its diagonal position so a
// wave of emphasis flows through the whole picture, like the template's
// drifting halftone videos.
const wavePeriod = 7

interface Cell {
  x: number
  y: number
  kind: 'square' | 'diamond' | 'icon'
  icon?: PixelIcon
  delay: string
}

const cells: Cell[] = []
for (let y = 0; y < rows; y++) {
  for (let x = 0; x < cols; x++) {
    const w = density(x, y) * 0.75 + rand() * 0.35
    let kind: Cell['kind'] | undefined
    let icon: PixelIcon | undefined
    if (w > 0.62) {
      kind = 'square'
    }
    else if (w > 0.52) {
      kind = 'diamond'
    }
    else if (w > 0.3 && rand() < 0.28) {
      kind = 'icon'
      icon = icons[Math.floor(rand() * icons.length)]
    }
    if (!kind)
      continue
    const phase = (x + y) / (cols + rows)
    cells.push({
      x,
      y,
      kind,
      icon,
      delay: `${(-(phase * wavePeriod) + rand() * 0.5).toFixed(2)}s`,
    })
  }
}

const uid = `pg${seed}`
---

<svg
  viewBox={`0 0 ${width} ${height}`}
  xmlns="http://www.w3.org/2000/svg"
  class={className}
  aria-hidden="true"
  role="presentation"
>
  <defs>
    <g id={`${uid}-robot`}>
      <rect x="2" y="4.5" width="8" height="6" rx="1" fill="none" stroke="currentColor" stroke-width="1.2" />
      <rect x="4" y="6.6" width="1.4" height="1.6" fill="currentColor" />
      <rect x="6.6" y="6.6" width="1.4" height="1.6" fill="currentColor" />
      <path d="M6 4.5V2.4" stroke="currentColor" stroke-width="1.2" />
      <circle cx="6" cy="1.7" r="0.9" fill="currentColor" />
    </g>
    <g id={`${uid}-gear`}>
      <circle cx="6" cy="6" r="2.1" fill="none" stroke="currentColor" stroke-width="1.3" />
      <path
        d="M6 1v1.6M6 9.4V11M1 6h1.6M9.4 6H11M2.5 2.5l1.1 1.1M8.4 8.4l1.1 1.1M9.5 2.5 8.4 3.6M3.6 8.4 2.5 9.5"
        stroke="currentColor"
        stroke-width="1.3"
      />
    </g>
    <g id={`${uid}-chip`}>
      <rect x="3" y="3" width="6" height="6" fill="none" stroke="currentColor" stroke-width="1.2" />
      <path
        d="M4.5 3V1M7.5 3V1M4.5 11V9M7.5 11V9M3 4.5H1M3 7.5H1M11 4.5H9M11 7.5H9"
        stroke="currentColor"
        stroke-width="1"
      />
    </g>
    <g id={`${uid}-wave`}>
      <path d="M0.5 6Q3 1.5 6 6T11.5 6" fill="none" stroke="currentColor" stroke-width="1.3" />
    </g>
    <g id={`${uid}-node`}>
      <circle cx="2.3" cy="2.6" r="1.4" fill="currentColor" />
      <circle cx="2.3" cy="9.4" r="1.4" fill="currentColor" />
      <circle cx="9.4" cy="6" r="1.6" fill="currentColor" />
      <path d="M3.5 3.3 8 5.4M3.5 8.7 8 6.6" stroke="currentColor" stroke-width="1" />
    </g>
    <g id={`${uid}-code`}>
      <path d="M4 2.5 1 6l3 3.5M8 2.5 11 6l-3 3.5" fill="none" stroke="currentColor" stroke-width="1.3" />
    </g>
  </defs>
  {
    cells.map(({ x, y, kind, icon, delay }) => {
      const cx = x * step + size / 2
      const cy = y * step + size / 2
      const anim = `animation-delay: ${delay};`
      if (kind === 'square')
        return (
          <rect x={x * step} y={y * step} width={size} height={size} fill="currentColor" class="pixel-wave" style={anim} />
        )
      if (kind === 'diamond')
        return (
          <rect
            x={x * step + 1.5}
            y={y * step + 1.5}
            width={size - 3}
            height={size - 3}
            fill="currentColor"
            transform={`rotate(45 ${cx} ${cy})`}
            class="pixel-wave"
            style={anim}
          />
        )
      return <use href={`#${uid}-${icon}`} x={x * step} y={y * step} class:list={['c-muted', 'pixel-wave']} style={anim} />
    })
  }
</svg>

<style>
  .pixel-wave {
    animation: pixel-wave 7s ease-in-out infinite;
  }

  /* A dip travelling along the diagonal delay gradient reads as a soft
     wave flowing through the whole field. */
  @keyframes pixel-wave {
    0%,
    28%,
    100% {
      opacity: 1;
    }
    14% {
      opacity: 0.3;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .pixel-wave {
      animation: none;
    }
  }
</style>
