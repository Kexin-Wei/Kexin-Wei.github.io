---
/**
 * Decorative glyph field inspired by the Researcher CV template, themed to
 * the site's content: a cluster of solid squares dissolves into tiny
 * hand-drawn icons (robot, gear, chip, sine wave, neural node, code)
 * with a subtle twinkle. Pure inline SVG — deterministic per seed.
 */
import type { PixelIcon } from '~/data/profile'

interface Props {
  cols?: number
  rows?: number
  seed?: number
  icons?: PixelIcon[]
  class?: string
}

const {
  cols = 48,
  rows = 22,
  seed = 7,
  icons = ['robot', 'gear', 'chip', 'wave', 'node', 'code'],
  class: className,
} = Astro.props

// Deterministic pseudo-random (mulberry32) so the pattern is stable per build
function mulberry32(a: number) {
  return () => {
    a |= 0
    a = (a + 0x6d2b79f5) | 0
    let t = Math.imul(a ^ (a >>> 15), 1 | a)
    t = (t + Math.imul(t ^ (t >>> 7), 61 | t)) ^ t
    return ((t ^ (t >>> 14)) >>> 0) / 4294967296
  }
}

const rand = mulberry32(seed)

// Two soft cluster centers give the field an organic, asymmetric weight
const centers = [
  { cx: 0.38 + rand() * 0.1, cy: 0.45 + rand() * 0.2, spread: 2.1 },
  { cx: 0.68 + rand() * 0.1, cy: 0.35 + rand() * 0.3, spread: 3.2 },
]

function density(x: number, y: number): number {
  let d = 0
  for (const { cx, cy, spread } of centers) {
    const dx = x / cols - cx
    const dy = y / rows - cy
    d = Math.max(d, 1 - Math.sqrt(dx * dx + dy * dy) * spread)
  }
  return Math.max(0, d)
}

const size = 12
const step = size + 4
const width = cols * step
const height = rows * step

interface Cell {
  x: number
  y: number
  kind: 'square' | 'diamond' | 'icon'
  icon?: PixelIcon
  flicker: boolean
  delay: string
  duration: string
}

const cells: Cell[] = []
for (let y = 0; y < rows; y++) {
  for (let x = 0; x < cols; x++) {
    const w = density(x, y) * 0.75 + rand() * 0.35
    let kind: Cell['kind'] | undefined
    let icon: PixelIcon | undefined
    if (w > 0.62) {
      kind = 'square'
    }
    else if (w > 0.52) {
      kind = 'diamond'
    }
    else if (w > 0.3 && rand() < 0.55) {
      kind = 'icon'
      icon = icons[Math.floor(rand() * icons.length)]
    }
    if (!kind)
      continue
    cells.push({
      x,
      y,
      kind,
      icon,
      flicker: rand() < 0.3,
      delay: `${(rand() * 5).toFixed(2)}s`,
      duration: `${(2 + rand() * 4).toFixed(2)}s`,
    })
  }
}

const uid = `pg${seed}`
---

<svg
  viewBox={`0 0 ${width} ${height}`}
  xmlns="http://www.w3.org/2000/svg"
  class={className}
  aria-hidden="true"
  role="presentation"
>
  <defs>
    <g id={`${uid}-robot`}>
      <rect x="2.5" y="3.5" width="7" height="6" rx="1" fill="none" stroke="currentColor" stroke-width="1.4" />
      <circle cx="4.8" cy="6.5" r="0.9" fill="currentColor" />
      <circle cx="7.2" cy="6.5" r="0.9" fill="currentColor" />
    </g>
    <g id={`${uid}-gear`}>
      <circle cx="6" cy="6" r="2" fill="none" stroke="currentColor" stroke-width="1.4" />
      <path d="M6 1.5v2M6 8.5v2M1.5 6h2M8.5 6h2" stroke="currentColor" stroke-width="1.4" />
    </g>
    <g id={`${uid}-chip`}>
      <rect x="3.5" y="3.5" width="5" height="5" fill="none" stroke="currentColor" stroke-width="1.4" />
      <circle cx="6" cy="6" r="1" fill="currentColor" />
    </g>
    <g id={`${uid}-wave`}>
      <path d="M1 6Q3.5 2 6 6T11 6" fill="none" stroke="currentColor" stroke-width="1.4" />
    </g>
    <g id={`${uid}-node`}>
      <circle cx="3" cy="3.5" r="1.3" fill="currentColor" />
      <circle cx="9" cy="8.5" r="1.3" fill="currentColor" />
      <path d="M4 4.3 8 7.7" stroke="currentColor" stroke-width="1.2" />
    </g>
    <g id={`${uid}-code`}>
      <path d="M4.5 3 1.5 6l3 3M7.5 3l3 3-3 3" fill="none" stroke="currentColor" stroke-width="1.4" />
    </g>
  </defs>
  {
    cells.map(({ x, y, kind, icon, flicker, delay, duration }) => {
      const cx = x * step + size / 2
      const cy = y * step + size / 2
      const anim = flicker ? `animation-delay: ${delay}; animation-duration: ${duration};` : undefined
      const cls = flicker ? 'pixel-flicker' : undefined
      if (kind === 'square')
        return <rect x={x * step} y={y * step} width={size} height={size} fill="currentColor" class={cls} style={anim} />
      if (kind === 'diamond')
        return (
          <rect
            x={x * step + 1.5}
            y={y * step + 1.5}
            width={size - 3}
            height={size - 3}
            fill="currentColor"
            transform={`rotate(45 ${cx} ${cy})`}
            class={cls}
            style={anim}
          />
        )
      return <use href={`#${uid}-${icon}`} x={x * step} y={y * step} class:list={['c-muted', cls]} style={anim} />
    })
  }
</svg>

<style>
  .pixel-flicker {
    animation-name: pixel-flicker;
    animation-iteration-count: infinite;
    animation-timing-function: steps(2, jump-none);
  }

  @keyframes pixel-flicker {
    0%,
    100% {
      opacity: 1;
    }
    50% {
      opacity: 0.25;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .pixel-flicker {
      animation: none;
    }
  }
</style>
