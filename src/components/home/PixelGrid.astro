---
/**
 * Decorative "pixel-art" grid in the style of the Researcher CV template:
 * a field of small squares where an organic cluster of cells is filled,
 * twinkling like the template's animated GIFs.
 * Pure inline SVG — no image assets, deterministic per seed.
 */
interface Props {
  cols?: number
  rows?: number
  seed?: number
  class?: string
}

const { cols = 48, rows = 22, seed = 7, class: className } = Astro.props

// Deterministic pseudo-random (mulberry32) so the pattern is stable per build
function mulberry32(a: number) {
  return () => {
    a |= 0
    a = (a + 0x6d2b79f5) | 0
    let t = Math.imul(a ^ (a >>> 15), 1 | a)
    t = (t + Math.imul(t ^ (t >>> 7), 61 | t)) ^ t
    return ((t ^ (t >>> 14)) >>> 0) / 4294967296
  }
}

const rand = mulberry32(seed)

function cellFilled(x: number, y: number, cols: number, rows: number, rand: () => number): boolean {
  // Density peaks at an off-center cluster and falls off with distance,
  // plus a low uniform floor for scattered stray pixels — mimics the
  // organic halftone look of the reference template.
  const dx = x / cols - 0.45
  const dy = y / rows - 0.55
  const dist = Math.sqrt(dx * dx + dy * dy)
  const cluster = Math.max(0, 0.85 - dist * 2.2)
  return rand() < cluster * cluster + 0.04
}

const size = 10
const gap = 2
const step = size + gap
const width = cols * step - gap
const height = rows * step - gap

interface Cell {
  x: number
  y: number
  delay: string
  duration: string
  flicker: boolean
}

const cells: Cell[] = []
for (let y = 0; y < rows; y++) {
  for (let x = 0; x < cols; x++) {
    if (cellFilled(x, y, cols, rows, rand)) {
      cells.push({
        x,
        y,
        // roughly half the cells twinkle, each on its own rhythm
        flicker: rand() < 0.5,
        delay: `${(rand() * 4).toFixed(2)}s`,
        duration: `${(1.5 + rand() * 3).toFixed(2)}s`,
      })
    }
  }
}
---

<svg
  viewBox={`0 0 ${width} ${height}`}
  xmlns="http://www.w3.org/2000/svg"
  class={className}
  aria-hidden="true"
  role="presentation"
>
  {
    cells.map(({ x, y, delay, duration, flicker }) => (
      <rect
        x={x * step}
        y={y * step}
        width={size}
        height={size}
        fill="currentColor"
        class={flicker ? 'pixel-flicker' : undefined}
        style={flicker ? `animation-delay: ${delay}; animation-duration: ${duration};` : undefined}
      />
    ))
  }
</svg>

<style>
  .pixel-flicker {
    animation-name: pixel-flicker;
    animation-iteration-count: infinite;
    animation-timing-function: steps(2, jump-none);
  }

  @keyframes pixel-flicker {
    0%,
    100% {
      opacity: 1;
    }
    50% {
      opacity: 0.1;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .pixel-flicker {
      animation: none;
    }
  }
</style>
