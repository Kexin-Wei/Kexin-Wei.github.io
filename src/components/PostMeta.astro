---
import type { Post } from '~/types'
import { formatDate } from '~/utils'
import PostCategory from './PostCategory.astro'

interface Props {
  post: Post
}

const { post } = Astro.props
const { translate: t } = Astro.locals

const categoryList = post.data.categories ?? []
---

<header class="rule-t not-prose pt-4 mb-8" flex="~ col gap-3">
  <div class="mono-label c-muted flex flex-wrap items-center gap-2">
    <span>{t(post.data.modDate ? 'updated_at' : 'posted_at')}</span>
    <time>{formatDate(post.data.modDate ?? post.data.pubDate)}</time>
    {categoryList.map((category) => <PostCategory category={category} />)}
  </div>
  <h1 class="m-0 font-ui font-normal c-primary" style="font-size: clamp(2rem, 5vw, 3.5rem); line-height: 1.1;">
    <a class="not-prose not-underline-hover hover:op-60" href={`/posts/${post.id}/`}>{post.data.title}</a>
  </h1>
</header>
