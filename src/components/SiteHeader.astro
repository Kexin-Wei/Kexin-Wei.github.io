---
import { themeConfig } from '~/.config'
import { profile } from '~/data/profile'

const { navLinks } = themeConfig.site

const initials = profile.name
  .split(' ')
  .map((part) => part[0])
  .join('')
---

<header class="flex justify-between items-start pt-5 pb-8">
  <a
    href="/"
    class="not-underline-hover inline-flex w-11 h-11 items-center justify-center bg-primary c-background font-mono font-bold text-4"
  >
    {initials}
  </a>
  <nav class="flex flex-row flex-wrap justify-end gap-x-5 gap-y-2 max-w-70vw">
    {
      navLinks.map((nav) => (
        <a
          href={nav.href}
          class:list={[
            'not-underline-hover font-mono text-3.5 hover:underline underline-offset-4',
            nav.highlight ? 'bg-primary c-background px-1.5' : 'c-primary',
          ]}
        >
          {nav.name}
        </a>
      ))
    }
  </nav>
</header>
