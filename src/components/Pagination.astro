---
const { translate: t } = Astro.locals

interface Props {
  showLeft?: boolean
  leftTitle?: string
  leftUrl?: string

  showRight?: boolean
  rightTitle?: string
  rightUrl?: string

  showPageCount?: boolean
  currentPage?: number
  totalPage?: number
}

const {
  showLeft = true,
  showRight = true,
  leftTitle,
  rightTitle,
  leftUrl,
  rightUrl,
  showPageCount = true,
  currentPage,
  totalPage,
} = Astro.props
---

<footer class="rule-t mt-10 pt-4 pb-8 flex items-baseline justify-between gap-4">
  <div class="flex items-baseline gap-6">
    {
      showLeft && (
        <a title={leftTitle} href={leftUrl} class="mono-link not-underline-hover">
          &lt; {leftTitle}
        </a>
      )
    }
    {
      showRight && (
        <a title={rightTitle} href={rightUrl} class="mono-link not-underline-hover">
          {rightTitle} &gt;
        </a>
      )
    }
  </div>
  {
    showPageCount && (
      <div class="mono-label c-muted">
        {t('page_number', currentPage)} / {t('page_count', totalPage)}
      </div>
    )
  }
</footer>
