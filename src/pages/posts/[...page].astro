---
import type { GetStaticPaths, InferGetStaticPropsType } from 'astro'
import { themeConfig } from '~/.config'
import Pagination from '~/components/Pagination.astro'
import SiteSeo from '~/components/SiteSeo.astro'
import LayoutDefault from '~/layouts/LayoutDefault.astro'
import { getCategories, getPathFromCategory, getPostDescription, getPosts } from '~/utils'

const { translate: t } = Astro.locals

export const getStaticPaths = (async ({ paginate }) => {
  // Defined inside getStaticPaths: Astro runs this in an isolated scope that
  // cannot see module-level helpers.
  const firstLocalImage = (body: string | undefined): string | null => {
    const match = body?.match(/!\[[^\]]*\]\((\/[^)\s]+)\)/)
    return match ? match[1] : null
  }
  const posts = await getPosts()
  posts.sort((a, b) => {
    if (a.data.pin && !b.data.pin) return -1
    if (!a.data.pin && b.data.pin) return 1
    return 0
  })
  // Precompute thumbnails here: `body` is not preserved once entries pass
  // through getStaticPaths props, so we resolve the first local image now.
  const withThumb = posts.map(post => ({ ...post, thumb: firstLocalImage(post.body) }))
  return paginate(withThumb, { pageSize: themeConfig.site.pageSize })
}) satisfies GetStaticPaths

type Props = InferGetStaticPropsType<typeof getStaticPaths>

const { page } = Astro.props

const categoryMap = await getCategories()
const tags = Array.from(categoryMap).map(([name, posts]) => ({
  name,
  count: posts.length,
  href: `/categories/${getPathFromCategory(name, themeConfig.site.categoryMap)}`,
}))
---

<LayoutDefault>
  <SiteSeo slot="seo" title={`Posts | ${themeConfig.site.title}`} desc={themeConfig.site.description} />

  <div class="rule-t pt-4 pb-10">
    <h1 class="m-0 font-ui font-normal c-primary" style="font-size: clamp(2rem, 5vw, 3.5rem); line-height: 1.1;">
      Archive of Posts
    </h1>
    <div class="mt-6 flex flex-wrap gap-x-4 gap-y-2">
      {
        tags.map(({ name, count, href }) => (
          <a href={href} class="not-underline-hover mono-label c-muted hover:c-primary">
            # {name} <span class="op-60">({count})</span>
          </a>
        ))
      }
    </div>
  </div>

  <ul class="m-0 p-0 list-none">
    {
      page.data.map((post, idx) => {
        const thumb = post.thumb
        return (
        <li class="rule-t">
          <a
            href={`/posts/${post.id}/`}
            class="not-underline-hover grid gap-4 py-6 lg:grid-cols-[8rem_1fr] lg:items-start group"
          >
            {thumb ? (
              <img src={thumb} alt="" loading="lazy" class="post-thumb w-full" style="height: 5rem; object-fit: cover;" />
            ) : (
              <span class="mono-label c-muted">
                {String((page.currentPage - 1) * themeConfig.site.pageSize + idx + 1).padStart(2, '0')}
              </span>
            )}
            <span flex="~ col gap-2">
              <span class="mono-label c-muted uppercase">
                {post.data.categories?.join(' • ')} • {post.data.pubDate.getFullYear()}
              </span>
              <span class="font-ui text-6 lg:text-8 c-primary lh-tight group-hover:op-60 transition-opacity">
                {post.data.title}
              </span>
              <span class="text-3.5 c-secondary max-w-3xl line-clamp-2">{getPostDescription(post)}</span>
            </span>
          </a>
        </li>
        )
      })
    }
  </ul>

  <Pagination
    showLeft={Boolean(page.url.prev)}
    leftTitle={t('prev')}
    leftUrl={page.url.prev}
    showRight={Boolean(page.url.next)}
    rightTitle={t('next')}
    rightUrl={page.url.next}
    currentPage={page.currentPage}
    totalPage={page.lastPage}
  />
</LayoutDefault>

<style>
  /* Muted, monochrome thumbnails so they blend with the minimal list. */
  .post-thumb {
    border-radius: 4px;
    border: 1px solid color-mix(in srgb, currentColor 12%, transparent);
    filter: grayscale(0.9) contrast(0.92);
    opacity: 0.72;
    transition: filter 0.25s ease, opacity 0.25s ease;
  }
  .group:hover .post-thumb {
    filter: grayscale(0);
    opacity: 1;
  }
</style>
