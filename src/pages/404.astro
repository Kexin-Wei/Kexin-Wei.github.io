---
import LayoutDefault from '~/layouts/LayoutDefault.astro'
---

<LayoutDefault>
  <div class="rule-t pt-4 pb-16">
    <p class="mono-label c-muted">Error 404</p>
    <h1
      class="m-0 font-header font-bold uppercase c-primary"
      style="font-size: clamp(2.5rem, 8.5vw, 6rem); line-height: 0.9; letter-spacing: -0.04em;"
    >
      Not Found
    </h1>
    <p class="mt-4 max-w-xl text-4 c-secondary">Sorry, we couldn't find the page you were looking for.</p>
    <a href="/" class="mono-link not-underline-hover">Go Home &gt;</a>
  </div>
</LayoutDefault>
