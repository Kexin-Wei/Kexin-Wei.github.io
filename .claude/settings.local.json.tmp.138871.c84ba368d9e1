{
  "permissions": {
    "allow": [
      "Bash(wc:*)",
      "mcp__playwright__browser_navigate",
      "mcp__playwright__browser_evaluate",
      "mcp__playwright__browser_take_screenshot",
      "Bash(pnpm add *)",
      "Bash(pnpm build *)",
      "Bash(git add *)",
      "Bash(git commit -m 'chore: remove theme cruft — comments, analytics, swup, upstream metadata *)",
      "mcp__playwright__browser_resize",
      "Bash(git mv *)",
      "Bash(git rm *)",
      "Bash(nohup pnpm preview --port 4321)",
      "Bash(curl -s -o /dev/null -w \"%{http_code}\" http://localhost:4321/)",
      "Bash(git commit -q -m 'feat: portfolio landing page in Researcher CV style, blog moved to /posts *)",
      "Bash(pnpm typecheck *)",
      "Bash(pnpm lint *)",
      "Bash(pnpm lint:fix)",
      "Bash(git commit -q -m 'feat: content-themed icon fields, cleaner hero meta line *)"
    ]
  }
}
